# DB
POSTGRES_DB=jinyverse
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# 로컬 볼륨 경로 (docker-compose.local.yml 사용 시 불필요)
POSTGRES_DATA_PATH=/your/local/path/data

# Spring DataSource (로컬 bootRun용)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5433/jinyverse
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# JWT (32자 이상)
JWT_SECRET=local_dev_secret_key_minimum_32_chars_here

# Mail (로컬에서는 false 권장)
MAIL_USE_SMTP=false
MAIL_USERNAME=
MAIL_PASSWORD=
